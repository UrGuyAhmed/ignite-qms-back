generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ContentBlock {
  id        String   @id @default(cuid())
  type      String
  value     String   @db.Text
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}