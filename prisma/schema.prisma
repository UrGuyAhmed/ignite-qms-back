generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  password String
}
model Content {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "hero_title", "about_image", "contact_banner"
  type      ContentType
  text      String?  // used when type = TEXT
  imageUrl  String?  // used when type = IMAGE, e.g. "/uploads/hero.jpg"
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum ContentType{
  TEXT
  IMAGE
}